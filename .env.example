# ═══════════════════════════════════════════
# SMART CARE POLYCLINIC — Backend Environment
# ═══════════════════════════════════════════

# Server
NODE_ENV=development
PORT=4000
CORS_ORIGIN=http://localhost:5173

# PostgreSQL
DATABASE_URL=postgresql://smartcare:smartcare_dev@localhost:5432/smartcare_db

# JWT Auth
JWT_SECRET=your-super-secret-key-change-in-production
JWT_EXPIRES_IN=7d

# Redis (for session caching & real-time)
REDIS_URL=redis://localhost:6379

# Twilio (OTP)
TWILIO_ACCOUNT_SID=your_twilio_sid
TWILIO_AUTH_TOKEN=your_twilio_token
TWILIO_PHONE_NUMBER=+1234567890

# Stripe (Payments)
STRIPE_SECRET_KEY=sk_test_your_stripe_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Google Gemini AI
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-3-flash-preview

# AWS S3 (File Uploads)
AWS_REGION=me-south-1
AWS_S3_BUCKET=smartcare-uploads
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key

# UAE Pass OAuth
UAEPASS_CLIENT_ID=your_uaepass_client_id
UAEPASS_CLIENT_SECRET=your_uaepass_client_secret
UAEPASS_REDIRECT_URI=http://localhost:4000/api/auth/uaepass/callback

# Unite EMR Integration
UNITE_EMR_BASE_URL=https://ucexternalapi-test.uniteemr.org
UNITE_EMR_APP_ID=your_unite_app_id
UNITE_EMR_APP_KEY=your_unite_app_key
UNITE_EMR_TOKEN=your_unite_initial_bearer_token

# Unite Appointment Integration (can be different from EMR credentials)
UNITE_APPOINTMENT_BASE_URL=https://ucexternalapi-test.uniteemr.org
UNITE_APPOINTMENT_APP_ID=your_unite_appointment_app_id
UNITE_APPOINTMENT_APP_KEY=your_unite_appointment_app_key
UNITE_APPOINTMENT_TOKEN=your_unite_appointment_initial_bearer_token

# OpenAI / ChatGPT (for medical assessment)
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-4o

# Upvio AI FaceVitals
UPVIO_BASE_URL=https://playground.upvio.ai
UPVIO_API_KEY=your_upvio_bearer_token
